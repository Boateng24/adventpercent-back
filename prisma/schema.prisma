// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}


model Song {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  artist          String
  album           String?
  genre           String?
  duration        Int?
  lyrics          String?
  playCount       Int         @default(0)
  skipCount       Int         @default(0)
  completeRate    Float       @default(0)
  shares          Int         @default(0)
  playlistAdds    Int         @default(0)
  track           String
  image           String?
  status          SongStatus  @default(PENDING)
  rejectionReason String?
  playlist        Playlist?   @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  playlistId      String?     @db.ObjectId
  trending        Trending[]
  createdAt       DateTime?   @default(now())
  favoritedBy     Favorite[]
  recentlyPlayed  RecentlyPlayed[]
}

model User {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  email             String    @unique
  password          String
  username          String
  firstname         String?
  lastname          String?
  provider          String?
  providerId        String?
  playlists         Playlist[]
  premium           Boolean   @default(false)
  userType          userType  @default(user)
  role              Role      @default(USER)
  favorites         Favorite[]
  recentlyPlayed    RecentlyPlayed[]
  resetToken        String?
  resetTokenExpiry  DateTime?
}

model Playlist {
  id    String   @id @default(auto()) @map("_id") @db.ObjectId
  name  String
  user  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String  @db.ObjectId
  songs Song[]   
}

model Trending {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  song          Song     @relation(fields: [songId], references: [id])
  songId        String   @db.ObjectId
  // New metrics
  dailyPlays    Int      @default(0)
  playVelocity  Float    @default(0)
  skipRate      Float    @default(0)
  shares        Int      @default(0)
  // Time tracking
  weekNumber    Int?
  year          Int?
  lastUpdated   DateTime @default(now())
  rank          Int?
  
  @@unique([songId, weekNumber, year])
  @@index([weekNumber, year])
  @@index([playVelocity])
}

model Favorite {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @db.ObjectId
  song   Song   @relation(fields: [songId], references: [id], onDelete: Cascade)
  songId String @db.ObjectId

  @@unique([userId, songId])
}

model RecentlyPlayed {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @db.ObjectId
  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  songId    String   @db.ObjectId
  playedAt  DateTime @default(now())
}

enum userType {
  artist
  user
}

enum SongStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  USER
  ARTIST
  ADMIN
}

