generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ARTIST
  ADMIN
}

enum userType {
  artist
  user
}

enum SongStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id               String           @id @default(auto()) @map("_id") @db.ObjectId
  email            String           @unique
  password         String
  username         String
  firstname        String?
  lastname         String?
  provider         String?
  providerId       String?
  premium          Boolean          @default(false)
  userType         userType         @default(user)
  role             Role             @default(USER)
  playlists        Playlist[]
  favorites        Favorite[]
  recentlyPlayed   RecentlyPlayed[]
  resetToken       String?
  resetTokenExpiry DateTime?
}

model Song {
  id              String           @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  artist          String
  album           String?
  genre           String?
  duration        Int?
  lyrics          String?
  playCount       Int              @default(0)
  skipCount       Int              @default(0)
  completeRate    Float            @default(0)
  shares          Int              @default(0)
  playlistAdds    Int              @default(0)
  track           String
  image           String?
  status          SongStatus       @default(PENDING)
  rejectionReason String?
  createdAt       DateTime?        @default(now())
  playlist        Playlist?        @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  playlistId      String?          @db.ObjectId
  trending        Trending[]
  favoritedBy     Favorite[]
  recentlyPlayed  RecentlyPlayed[]
}

model Playlist {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  name   String
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  songs  Song[]
}

model Trending {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  songId       String   @db.ObjectId
  song         Song     @relation(fields: [songId], references: [id])
  dailyPlays   Int      @default(0)
  playVelocity Float    @default(0)
  skipRate     Float    @default(0)
  shares       Int      @default(0)
  weekNumber   Int?
  year         Int?
  lastUpdated  DateTime @default(now())
  rank         Int?

  @@unique([songId, weekNumber, year])
  @@index([weekNumber, year])
  @@index([playVelocity])
}

model Favorite {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  songId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  song   Song   @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([userId, songId])
}

model RecentlyPlayed {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  userId   String   @db.ObjectId
  songId   String   @db.ObjectId
  playedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  song     Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
}
